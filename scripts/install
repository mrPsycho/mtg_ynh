#!/bin/bash

#=================================================
# COMMON VARIABLES AND HELPERS
#=================================================
source /usr/share/yunohost/helpers

app=$YNH_APP_ID

# Read arguments
port=$YNH_APP_ARG_PORT
secret_or_domain=$YNH_APP_ARG_SECRET
dns_ip=$YNH_APP_ARG_DNS
prometheus=$YNH_APP_ARG_PROMETHEUS

# install_dir is automatically set by YunoHost from [resources.install_dir]
conf_dir=/etc/$app

#=================================================
# FETCH AND INSTALL MTG
#=================================================
ynh_script_progression --message="Downloading mtg binary..." --weight=3

# Map YunoHost architecture to mtg release architecture
case "$YNH_ARCH" in
    amd64)  MTG_ARCH="linux-amd64" ;;
    armhf)  MTG_ARCH="linux-arm-7" ;;
    arm64)  MTG_ARCH="linux-arm64" ;;
    i386)   MTG_ARCH="linux-386" ;;
    *)      ynh_die "Unsupported architecture: $YNH_ARCH" ;;
esac

# Fetch the latest release URL
LATEST_RELEASE_URL=$(curl -s "https://api.github.com/repos/9seconds/mtg/releases/latest" | jq -r ".assets[] | select(.name | contains(\"${MTG_ARCH}.tar.gz\")) | .browser_download_url")

if [ -z "$LATEST_RELEASE_URL" ] || [ "$LATEST_RELEASE_URL" == "null" ]; then
    ynh_die "Failed to find the latest mtg release for architecture $MTG_ARCH."
fi

# Download and extract the archive into install_dir (auto-created by resources)
cd "$install_dir" || ynh_die "Failed to enter $install_dir"
curl -sL "$LATEST_RELEASE_URL" | tar -xz --strip-components=1
chmod +x "$install_dir/mtg"

#=================================================
# CONFIGURE MTG
#=================================================
ynh_script_progression --message="Configuring mtg..." --weight=2

# If secret doesn't start with 'ee', treat it as a domain and auto-generate
if [[ "$secret_or_domain" == ee* ]]; then
    SECRET="$secret_or_domain"
else
    ynh_print_info "Generating MTProto secret for fronting domain: $secret_or_domain"
    SECRET=$("$install_dir/mtg" generate-secret "$secret_or_domain")
    if [ -z "$SECRET" ]; then
        ynh_die "Failed to generate mtg secret for domain $secret_or_domain"
    fi
    ynh_print_info "Generated secret: $SECRET"
fi

# Save the effective port from resources (may differ from requested if taken)
port=$(ynh_app_setting_get --app="$app" --key=port)

mkdir -p "$conf_dir"

if [ "$prometheus" -eq 1 ]; then
    PROM_ENABLED="true"
else
    PROM_ENABLED="false"
fi

cat <<EOF > "$conf_dir/mtg.toml"
debug = false
secret = "${SECRET}"
bind-to = "0.0.0.0:${port}"

[network]
dns = "https://${dns_ip}"

[stats.prometheus]
enabled = ${PROM_ENABLED}
bind-to = "127.0.0.1:3129"
http-path = "/"
metric-prefix = "mtg"
EOF

chmod 600 "$conf_dir/mtg.toml"
chown -R "$app:" "$install_dir" "$conf_dir"

#=================================================
# SYSTEMD
#=================================================
ynh_script_progression --message="Setting up systemd service..." --weight=2

ynh_add_systemd_config
ynh_systemd_action --action=enable --service_name="$app"
ynh_systemd_action --action=start --service_name="$app"

#=================================================
# DONE
#=================================================
ynh_script_progression --message="Installation complete!" --weight=1
