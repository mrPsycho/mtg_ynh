#!/bin/bash

#=================================================
# COMMON VARIABLES AND HELPERS
#=================================================

source /usr/share/yunohost/helpers

conf_dir=$install_dir/conf

#=================================================
# FETCH AND INSTALL MTG BINARY
#=================================================
ynh_script_progression "Setting up source files..."

ynh_setup_source --dest_dir="$install_dir"

chmod +x "$install_dir/mtg"

#=================================================
# GENERATE/VALIDATE SECRET
#=================================================
ynh_script_progression "Adding $app's configuration files..."

if [[ "$secret" == ee* ]]; then
    mtg_secret="$secret"
else
    ynh_print_info "Generating MTProto secret for fronting domain: $secret"
    mtg_secret=$("$install_dir/mtg" generate-secret "$secret")
    [ -z "$mtg_secret" ] && ynh_die "Failed to generate mtg secret for domain $secret"
    ynh_print_info "Generated secret: $mtg_secret"
fi

ynh_app_setting_set --key=mtg_secret --value="$mtg_secret"

#=================================================
# WRITE CONFIGURATION
#=================================================

mkdir -p "$conf_dir"

# Create log directory
mkdir -p /var/log/$app
chown -R "$app:www-data" "/var/log/$app"

[ "$prometheus" = "1" ] && prom_enabled="true" || prom_enabled="false"

ynh_config_add --template="mtg.toml" --destination="$conf_dir/mtg.toml"

#=================================================
# SYSTEMD + SERVICE REGISTRATION
#=================================================
ynh_script_progression "Setting up systemd service..."

ynh_config_add_systemd

yunohost service add "$app" \
    --description "MTProto proxy for Telegram" \
    --needs_exposed_ports "$port" \
    --log="/var/log/$app/mtg.log" 

#=================================================
# START SYSTEMD SERVICE
#=================================================
ynh_script_progression "Starting $app's systemd service..."

ynh_systemctl --action=enable
ynh_systemctl --action=start

#=================================================
# END OF SCRIPT
#=================================================

ynh_script_progression "Installation of $app completed"
